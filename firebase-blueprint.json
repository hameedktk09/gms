{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user details database entry representing an admin or instructor.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "instructor"] },
        "approved": { "type": "boolean" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "subject": { "type": "string" },
        "mustChangePassword": { "type": "boolean" }
      },
      "required": ["uid", "email", "fullName", "role", "username", "password"]
    },
    "RegistrationRequest": {
      "title": "RegistrationRequest",
      "description": "An instructor registration request pending review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" },
        "generatedUsername": { "type": "string" },
        "generatedPassword": { "type": "string" }
      },
      "required": ["id", "fullName", "email", "status"]
    },
    "SectionGrade": {
      "title": "SectionGrade",
      "description": "Section grade data, including student records and configurations.",
      "type": "object",
      "properties": {
        "students": { "type": "array" },
        "isLocked": { "type": "boolean" },
        "formData": { "type": "object" }
      },
      "required": ["students", "isLocked", "formData"]
    },
    "AIReport": {
      "title": "AIReport",
      "description": "AI statistical analysis report for a section.",
      "type": "object",
      "properties": {
        "categoryPerformance": { "type": "string" },
        "descriptiveAnalysis": { "type": "string" },
        "genderDemographics": { "type": "string" },
        "completionInsights": { "type": "string" },
        "cerComments": { "type": "string" },
        "cerExplanation": { "type": "string" },
        "cerRecommendations": { "type": "string" },
        "cerOverallView": { "type": "string" }
      },
      "required": ["categoryPerformance", "descriptiveAnalysis"]
    },
    "StudentRemarks": {
      "title": "StudentRemarks",
      "description": "Custom academic remarks or petition response for a student.",
      "type": "object",
      "properties": {
        "remarks": { "type": "string" }
      },
      "required": ["remarks"]
    },
    "FeedbackReport": {
      "title": "FeedbackReport",
      "description": "Student evaluation and feedback analysis report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "courseCode": { "type": "string" },
        "courseTitle": { "type": "string" },
        "section": { "type": "string" },
        "instructorName": { "type": "string" },
        "instructorUsername": { "type": "string" },
        "semester": { "type": "string" },
        "metrics": { "type": "object" },
        "analysis": { "type": "object" },
        "originalText": { "type": "string" }
      },
      "required": ["id", "uploadedBy", "createdAt", "courseCode", "courseTitle", "section", "instructorName"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "Instructors and administrators registered in the system."
    },
    "/registrationRequests/{requestId}": {
      "schema": "RegistrationRequest",
      "description": "User registration requests awaiting administrator's approval."
    },
    "/sectionGrades/{sectionKey}": {
      "schema": "SectionGrade",
      "description": "Section lists and grades keyed by composite section codes."
    },
    "/aiReports/{sectionKey}": {
      "schema": "AIReport",
      "description": "AI analytical feedback and comments for course sections."
    },
    "/studentRemarks/{remarksId}": {
      "schema": "StudentRemarks",
      "description": "Section student comments generated by AI or edited manually."
    },
    "/feedbackReports/{reportId}": {
      "schema": "FeedbackReport",
      "description": "Aggregated surveyed course feedback evaluations and ratings."
    }
  }
}
